 *
 * This file is generated by CMake from config.h.in — do not edit directly.
 * When adding a new PROMEKI_ENABLE_* flag, also update
 * src/core/buildinfo.cpp.in (buildFeatureString) so it appears in
 * build-info output.
 */

#pragma once

/**
 * @section feature_flag_convention How to test PROMEKI_ENABLE_* flags
 *
 * Every @c PROMEKI_ENABLE_* macro is emitted via CMake's
 * @c \#cmakedefine01, which means each flag is @b always defined and
 * expands to either @c 0 or @c 1.  It is @b never undefined.  As a
 * result:
 *
 * @code
 * #if PROMEKI_ENABLE_TLS              // CORRECT — tests the value (0 or 1)
 * #if !PROMEKI_ENABLE_TLS             // CORRECT — negation of value
 * #if defined(PROMEKI_ENABLE_TLS)     // WRONG — always true, even when TLS is off
 * #ifdef PROMEKI_ENABLE_TLS           // WRONG — same trap as above
 * @endcode
 *
 * @c \#if @c defined(PROMEKI_ENABLE_X) compiles cleanly and silently
 * does the wrong thing — the guarded block stays in even with the
 * feature disabled.  Reviewers should flag any @c defined() /
 * @c \#ifdef on a @c PROMEKI_ENABLE_* macro as a bug.
 *
 * The single exception is @c PROMEKI_ENABLE_CORE, which is hard-wired
 * to @c 1 via a plain @c \#define below — its value can still be
 * tested with @c \#if and the bare-defined() check would happen to
 * give the right answer there too, but the convention is uniform:
 * always use @c \#if for any @c PROMEKI_ENABLE_* macro.
 */
#cmakedefine01 PROMEKI_ENABLE_NETWORK
#cmakedefine01 PROMEKI_ENABLE_HTTP
#cmakedefine01 PROMEKI_ENABLE_TLS
#cmakedefine01 PROMEKI_ENABLE_PROAV
#cmakedefine01 PROMEKI_ENABLE_MUSIC
#cmakedefine01 PROMEKI_ENABLE_PNG
#cmakedefine01 PROMEKI_ENABLE_JPEG
#cmakedefine01 PROMEKI_ENABLE_JPEGXS
#cmakedefine01 PROMEKI_ENABLE_X264
#cmakedefine01 PROMEKI_ENABLE_FREETYPE
#cmakedefine01 PROMEKI_ENABLE_AUDIO
#cmakedefine01 PROMEKI_ENABLE_FLAC
#cmakedefine01 PROMEKI_ENABLE_VORBIS
#cmakedefine01 PROMEKI_ENABLE_MP3
#cmakedefine01 PROMEKI_ENABLE_OPUS
#cmakedefine01 PROMEKI_ENABLE_AAC
#cmakedefine01 PROMEKI_ENABLE_WHISPER
#cmakedefine01 PROMEKI_ENABLE_SRC
#cmakedefine01 PROMEKI_ENABLE_CSC
#cmakedefine01 PROMEKI_ENABLE_CIRF
#cmakedefine01 PROMEKI_ENABLE_V4L2
#cmakedefine01 PROMEKI_ENABLE_CUDA
#cmakedefine01 PROMEKI_ENABLE_NVENC
#cmakedefine01 PROMEKI_ENABLE_NVDEC
#cmakedefine01 PROMEKI_ENABLE_NDI
#cmakedefine01 PROMEKI_ENABLE_NTV2
#cmakedefine01 PROMEKI_ENABLE_SRT
#cmakedefine01 PROMEKI_ENABLE_MDNS
#cmakedefine01 PROMEKI_ENABLE_MEMFD
#cmakedefine01 PROMEKI_ENABLE_DMABUF

/* Set when any GPL-licensed component (e.g. x264) is enabled; the build is
 * then subject to the GPL.  See THIRD-PARTY-LICENSES. */
#cmakedefine01 PROMEKI_GPL_BUILD

/**
 * @brief Always-on marker for the library's core surface.
 *
 * Every public header in @c include/promeki/ wraps its body in a
 * @c \#if @c PROMEKI_ENABLE_* guard so the convention is uniform and
 * a missing gate is easy to spot in review.  @c PROMEKI_ENABLE_CORE
 * is the gate used by headers whose declarations must always be
 * available — it has no user-facing CMake option and is hard-wired
 * to @c 1.  See @ref header_gating below.
 */
#define PROMEKI_ENABLE_CORE 1

#cmakedefine01 PROMEKI_HAVE_CXA_DEMANGLE

/**
 * @section header_gating Header-gating convention
 *
 * The library follows a strict layering chain — each level is a
 * superset of the previous:
 *
 * @code
 *   CORE  →  PROAV  →  NETWORK  →  HTTP
 *                                ↘  TLS  →  SRT
 * @endcode
 *
 * Enabling a higher level forces the lower levels on; @c CMakeLists.txt
 * enforces this with @c FATAL_ERROR checks.  That means code at level
 * @i N is free to use @b any type from levels @c 1..N.  In particular,
 * @c NETWORK code can freely use @c PROAV types like @ref Frame and
 * @ref AudioBuffer because @c PROAV is guaranteed on whenever
 * @c NETWORK is on.  Only references in the @b other direction (lower
 * level using higher-level types) are problematic — see the CORE
 * exception below.
 *
 * Every public header in @c include/promeki/ wraps its body in a
 * @c \#if guard naming a single @c PROMEKI_ENABLE_* flag.  Mechanical,
 * uniform, no dual gates.  Use @c \#if (not @c \#if @c defined() —
 * see @ref feature_flag_convention above):
 *
 * @code
 * #pragma once
 * #include <promeki/config.h>
 * #if PROMEKI_ENABLE_<FLAG>
 *
 * ... header body ...
 *
 * #endif // PROMEKI_ENABLE_<FLAG>
 * @endcode
 *
 * The chosen flag is the @b highest level the header reaches.  For
 * example, @c framebridge.h uses @c LocalSocket (a NETWORK type) even
 * though it ships frames (PROAV) — its gate is @c NETWORK, not
 * @c PROAV.  Consumers can include the header unconditionally; with
 * @c NETWORK off the body elides to nothing.
 *
 * @subsection header_gating_core PROMEKI_ENABLE_CORE
 *
 * @c PROMEKI_ENABLE_CORE is hard-wired to @c 1.  It tags headers
 * whose declarations must always be visible.  This includes the
 * usual plain core types (@ref String, @ref Buffer, etc.) and also
 * a small set of feature-implemented types referenced from ungated
 * core code — e.g. @ref Subtitle, @ref Eui64, @ref SocketAddress
 * are registered as @ref Variant payload types in @c variant.cpp.
 * Their @c .cpp files still live in a feature directory and only
 * link when that feature is ON; consumers that @i use the type get
 * a link error in a stripped-down build, but the declaration is
 * always available so unconditional @c \#include is safe.
 */
