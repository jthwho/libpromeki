#include <promeki/buildinfo.h>
#include <promeki/config.h>
#include <promeki/platform.h>
#include <promeki/logger.h>
#include <promeki/error.h>
#include <promeki/buildident.h>
#include <cstring>
#include <cstdlib>
#include <thread>
#if defined(PROMEKI_PLATFORM_POSIX)
#include <unistd.h>
#elif defined(PROMEKI_PLATFORM_WINDOWS)
#include <process.h>
#endif

PROMEKI_NAMESPACE_BEGIN

static const char *_buildType() {
#ifdef PROMEKI_COMPILER_MSVC
#   ifdef _DEBUG
    return "Debug";
#   else
    return "Release";
#   endif
#else
    return "@BUILD_INFO_TYPE@";
#endif

};

static const BuildInfo _buildInfo = {
    "@BUILD_INFO_NAME@",
    "@BUILD_INFO_VERSION@",
    "@BUILD_INFO_REPOIDENT@",
    "@BUILD_INFO_REF@",
    "@BUILD_INFO_DATE@",
    "@BUILD_INFO_TIME@",
    "@BUILD_INFO_HOSTNAME@",
    _buildType(),
    @BUILD_INFO_VERSION_MAJOR@,
    @BUILD_INFO_VERSION_MINOR@,
    @BUILD_INFO_VERSION_PATCH@,
    @BUILD_INFO_VERSION_BUILD@,
    @BUILD_INFO_VERSION_STAGE@,
    @BUILD_INFO_VERSION_STAGE_NUM@,
    "@BUILD_INFO_IDENT@"
};

const BuildInfo *getBuildInfo() {
    return &_buildInfo;
}

const char *buildStageName(BuildStage stage) {
        switch (stage) {
                case BuildStage::Alpha:   return "alpha";
                case BuildStage::Beta:    return "beta";
                case BuildStage::RC:      return "rc";
                case BuildStage::Release: return "release";
        }
        return "unknown";
}

// Compose the pre-release suffix the same way CMake composes it for the
// build ident: "-alpha"/"-beta" omit the "1" when stageNum==1, "-rcN"
// always carries its number, and Release contributes nothing.
static String _stageSuffix(const BuildInfo &bi) {
        if (bi.stage == BuildStage::Release) return String();
        String out = "-";
        out += buildStageName(bi.stage);
        const bool numbered = (bi.stage == BuildStage::RC) || bi.stageNum > 1;
        if (numbered) out += String::number(bi.stageNum);
        return out;
}

String formatBuildInfo(const String &fmt, const BuildInfo *bi) {
        if (bi == nullptr) bi = &_buildInfo;
        String      out;
        const char *p   = fmt.cstr();
        const char *end = p + fmt.size();
        while (p < end) {
                // "}}" → literal "}"
                if (*p == '}' && p + 1 < end && p[1] == '}') {
                        out += '}';
                        p += 2;
                        continue;
                }
                if (*p != '{') {
                        out += *p++;
                        continue;
                }
                // "{{" → literal "{"
                if (p + 1 < end && p[1] == '{') {
                        out += '{';
                        p += 2;
                        continue;
                }
                const char *close = static_cast<const char *>(std::memchr(p + 1, '}', end - (p + 1)));
                if (close == nullptr) {
                        // Unbalanced brace — emit the rest verbatim and stop.
                        out += String(p, end - p);
                        break;
                }
                String token(p + 1, close - p - 1);
                if      (token == "name")      out += bi->name      ? bi->name      : "";
                else if (token == "version")   out += bi->version   ? bi->version   : "";
                else if (token == "major")     out += String::number(bi->major);
                else if (token == "minor")     out += String::number(bi->minor);
                else if (token == "patch")     out += String::number(bi->patch);
                else if (token == "build")     out += String::number(bi->build);
                else if (token == "stage")     out += buildStageName(bi->stage);
                else if (token == "stageNum")  out += String::number(bi->stageNum);
                else if (token == "extra")     out += _stageSuffix(*bi);
                else if (token == "date")      out += bi->date      ? bi->date      : "";
                else if (token == "time")      out += bi->time      ? bi->time      : "";
                else if (token == "type")      out += bi->type      ? bi->type      : "";
                else if (token == "hostname")  out += bi->hostname  ? bi->hostname  : "";
                else if (token == "repoident") out += bi->repoident ? bi->repoident : "";
                else if (token == "ref")       out += bi->ref       ? bi->ref       : "";
                else if (token == "ident")     out += bi->ident     ? bi->ident     : "";
                else {
                        // Unknown token — emit verbatim as a debugging aid.
                        out += '{';
                        out += token;
                        out += '}';
                }
                p = close + 1;
        }
        return out;
}

void logBuildInfo() {
        // Match the format used by buildInfoString() so log + banner agree.
        promekiInfo("%s", buildInfoString().cstr());
}

String buildInfoString() {
        return formatBuildInfo("{name} v{version}{extra} {{{repoident} on {ref}}} [{type}] (Built {date} {time} by {hostname})");
}

String buildPlatformString() {
        String compiler;
#if defined(PROMEKI_COMPILER_CLANG)
        compiler = String::sprintf("Clang %d.%d.%d",
                __clang_major__, __clang_minor__, __clang_patchlevel__);
#elif defined(PROMEKI_COMPILER_GCC)
        compiler = String::sprintf("GCC %d.%d.%d",
                __GNUC__, __GNUC_MINOR__, __GNUC_PATCHLEVEL__);
#elif defined(PROMEKI_COMPILER_MSVC)
        compiler = String::sprintf("MSVC %d", _MSC_VER);
#else
        compiler = "Unknown";
#endif
        return String::sprintf("Platform: %s | Compiler: %s | C++: %ld",
                PROMEKI_PLATFORM, compiler.cstr(), (long)__cplusplus);
}

String buildFeatureString() {
        StringList features;
#if PROMEKI_ENABLE_NETWORK
        features += "NETWORK";
#endif
#if PROMEKI_ENABLE_HTTP
        features += "HTTP";
#endif
#if PROMEKI_ENABLE_TLS
        features += "TLS";
#endif
#if PROMEKI_ENABLE_PROAV
        features += "PROAV";
#endif
#if PROMEKI_ENABLE_MUSIC
        features += "MUSIC";
#endif
#if PROMEKI_ENABLE_PNG
        features += "PNG";
#endif
#if PROMEKI_ENABLE_JPEG
        features += "JPEG";
#endif
#if PROMEKI_ENABLE_JPEGXS
        features += "JPEGXS";
#endif
#if PROMEKI_ENABLE_FREETYPE
        features += "FREETYPE";
#endif
#if PROMEKI_ENABLE_AUDIO
        features += "AUDIO";
#endif
#if PROMEKI_ENABLE_OPUS
        features += "OPUS";
#endif
#if PROMEKI_ENABLE_SRC
        features += "SRC";
#endif
#if PROMEKI_ENABLE_CSC
        features += "CSC";
#endif
#if PROMEKI_ENABLE_CIRF
        features += "CIRF";
#endif
#if PROMEKI_ENABLE_V4L2
        features += "V4L2";
#endif
#if PROMEKI_ENABLE_CUDA
        features += "CUDA";
#endif
#if PROMEKI_ENABLE_NVENC
        features += "NVENC";
#endif
#if PROMEKI_ENABLE_NVDEC
        features += "NVDEC";
#endif
        return String::sprintf("Features: %s",
                features.isEmpty() ? "(none)" : features.join(" ").cstr());
}

String runtimeInfoString() {
        int cpus = static_cast<int>(std::thread::hardware_concurrency());
#if defined(PROMEKI_PLATFORM_POSIX)
        return String::sprintf("Hardware: %d CPUs | PID: %d",
                cpus, (int)getpid());
#elif defined(PROMEKI_PLATFORM_WINDOWS)
        return String::sprintf("Hardware: %d CPUs | PID: %d",
                cpus, (int)_getpid());
#else
        return String::sprintf("Hardware: %d CPUs", cpus);
#endif
}

String debugStatusString() {
#ifdef PROMEKI_DEBUG_ENABLE
        return "promekiDebug() logging: compiled in";
#else
        return "promekiDebug() logging: compiled out (Release build)";
#endif
}

StringList buildInfoStrings() {
        return {
                buildInfoString(),
                buildPlatformString(),
                buildFeatureString(),
                runtimeInfoString(),
                debugStatusString()
        };
}

bool verifyBuildIdent(const char *expected, Error *err) {
        const char *actual = _buildInfo.ident;
        if (expected != nullptr && actual != nullptr && std::strcmp(expected, actual) == 0) {
                if (err) *err = Error::Ok;
                return true;
        }
        promekiErr("Build identity mismatch — caller is stale against libpromeki. "
                   "expected=\"%s\" actual=\"%s\"",
                   expected ? expected : "(null)",
                   actual   ? actual   : "(null)");
        if (err) *err = Error::BuildIdentMismatch;
        return false;
}

void verifyBuildIdentOrAbort(const char *expected) {
        if (verifyBuildIdent(expected, nullptr)) return;
        // Flush log queue before abort so the diagnostic actually reaches the console / log.
        promekiLogSync();
        std::abort();
}

PROMEKI_NAMESPACE_END

