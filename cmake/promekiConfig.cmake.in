@PACKAGE_INIT@

# Import core targets
include("${CMAKE_CURRENT_LIST_DIR}/promeki-core-targets.cmake")

# Import proav targets if they were built and installed
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/promeki-proav-targets.cmake")
