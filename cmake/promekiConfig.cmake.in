@PACKAGE_INIT@

# Import main library targets
include("${CMAKE_CURRENT_LIST_DIR}/promeki-targets.cmake")

# Import TUI targets if they were built and installed
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/promeki-tui-targets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/promeki-tui-targets.cmake")
endif()

# Import SDL targets if they were built and installed
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/promeki-sdl-targets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/promeki-sdl-targets.cmake")
endif()

check_required_components(promeki)
