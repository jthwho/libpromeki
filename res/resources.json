{
    "metadata": {
        "library": "libpromeki",
        "description": "Built-in compiled-in resources for libpromeki, exposed under :/.PROMEKI/"
    },
    "entries": [
        {
            "type": "folder",
            "path": ".PROMEKI/fonts",
            "entries": [
                {
                    "type": "file",
                    "path": "FiraCodeNerdFontMono-Regular.ttf",
                    "source": "./.PROMEKI/fonts/FiraCodeNerdFontMono-Regular.ttf"
                }
            ]
        },
        {
            "type": "folder",
            "path": ".PROMEKI/debug",
            "entries": [
                {
                    "type": "file",
                    "path": "index.html",
                    "source": "./.PROMEKI/debug/index.html"
                },
                {
                    "type": "file",
                    "path": "app.js",
                    "source": "./.PROMEKI/debug/app.js"
                },
                {
                    "type": "file",
                    "path": "style.css",
                    "source": "./.PROMEKI/debug/style.css"
                }
            ]
        },
        {
            "type": "folder",
            "path": ".PROMEKI/explorer",
            "entries": [
                {
                    "type": "file",
                    "path": "index.html",
                    "source": "./.PROMEKI/explorer/index.html"
                },
                {
                    "type": "file",
                    "path": "app.js",
                    "source": "./.PROMEKI/explorer/app.js"
                },
                {
                    "type": "file",
                    "path": "style.css",
                    "source": "./.PROMEKI/explorer/style.css"
                }
            ]
        }
    ]
}
